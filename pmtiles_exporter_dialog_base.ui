<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>PMTilesExporterDialogBase</class>
 <widget class="QDialog" name="PMTilesExporterDialogBase">
  <property name="windowTitle">
   <string>PMTiles Exporter</string>
  </property>

  <layout class="QVBoxLayout" name="verticalLayout">

   <!-- 出力範囲選択 -->
   <item>
    <widget class="QGroupBox" name="groupExtent">
     <property name="title">
      <string>出力範囲</string>
     </property>
     <layout class="QHBoxLayout">
      <item>
       <widget class="QRadioButton" name="radCanvas">
        <property name="text">
         <string>現在のキャンバス範囲</string>
        </property>
        <property name="checked">
         <bool>true</bool>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QRadioButton" name="radLayer">
        <property name="text">
         <string>レイヤー結合範囲</string>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>

   <!-- CRS選択 -->
   <item>
    <widget class="QGroupBox" name="groupCRS">
     <property name="title">
      <string>座標系（日本平面直角座標系）</string>
     </property>
     <layout class="QHBoxLayout">
      <item>
       <widget class="QComboBox" name="cmbCRS"/>
      </item>
     </layout>
    </widget>
   </item>

   <!-- タイル形式選択 -->
   <item>
    <widget class="QGroupBox" name="groupTileFormat">
     <property name="title">
      <string>タイル形式</string>
     </property>
     <layout class="QHBoxLayout">
      <item>
       <widget class="QComboBox" name="cmbTileFormat">
        <item>
         <property name="text">
          <string>XYZタイル</string>
         </property>
        </item>
        <item>
         <property name="text">
          <string>MBTiles</string>
         </property>
        </item>
        <item>
         <property name="text">
          <string>PMTiles</string>
         </property>
        </item>
       </widget>
      </item>
     </layout>
    </widget>
   </item>

   <!-- レイヤーツリー -->
   <item>
    <widget class="QGroupBox" name="groupLayers">
     <property name="title">
      <string>レイヤー選択</string>
     </property>
     <layout class="QVBoxLayout">
      <item>
       <widget class="QWidget" name="layer_tree_container">
        <layout class="QVBoxLayout" name="layerTreeLayout"/>
       </widget>
      </item>
     </layout>
    </widget>
   </item>

   <!-- ズーム範囲 -->
   <item>
    <widget class="QGroupBox" name="groupZoom">
     <property name="title">
      <string>ズーム範囲</string>
     </property>
     <layout class="QHBoxLayout">
      <item>
       <widget class="QLabel" name="labelMinZoom">
        <property name="text">
         <string>最小ズーム</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QSpinBox" name="spinMinZoom">
        <property name="minimum">
         <number>0</number>
        </property>
        <property name="maximum">
         <number>22</number>
        </property>
        <property name="value">
         <number>0</number>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QLabel" name="labelMaxZoom">
        <property name="text">
         <string>最大ズーム</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QSpinBox" name="spinMaxZoom">
        <property name="minimum">
         <number>0</number>
        </property>
        <property name="maximum">
         <number>22</number>
        </property>
        <property name="value">
         <number>5</number>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>

   <!-- 保存先 -->
   <item>
    <widget class="QGroupBox" name="groupOutput">
     <property name="title">
      <string>保存先フォルダ</string>
     </property>
     <layout class="QHBoxLayout">
      <item>
       <widget class="QLineEdit" name="txtOutputPath"/>
      </item>
      <item>
       <widget class="QPushButton" name="btnBrowse">
        <property name="text">
         <string>参照</string>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>

   <!-- 進捗 -->
   <item>
    <widget class="QGroupBox" name="groupProgress">
     <property name="title">
      <string>進捗</string>
     </property>
     <layout class="QVBoxLayout">
      <item>
       <widget class="QLabel" name="label_progress">
        <property name="text">
         <string>準備中…</string>
        </property>
        <property name="visible">
         <bool>false</bool>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QProgressBar" name="progressBar">
        <property name="visible">
         <bool>false</bool>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>

   <!-- OK / Cancel -->
   <item>
    <widget class="QDialogButtonBox" name="buttonBox">
     <property name="standardButtons">
      <set>QDialogButtonBox::Ok|QDialogButtonBox::Cancel</set>
     </property>
    </widget>
   </item>

  </layout>
 </widget>

 <resources/>
 <connections/>
</ui>
